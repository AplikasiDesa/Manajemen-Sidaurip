rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNGSI PEMBANTU ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             ('email' in request.auth.token) &&
             request.auth.token.email == 'sidaurip@gmail.id';
    }

    // --- KOLEKSI PUBLIK ---
    
    match /officials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /villageLogo/{id} { allow read: if true; allow write: if isAdmin(); }
    match /kopSurat/{id} { allow read: if true; allow write: if isAdmin(); }
    match /heroImage/{id} { allow read: if true; allow write: if isAdmin(); }
    
    // --- KOLEKSI PRIVATE ---
    
    match /residents/{nik} {
      // Izinkan warga yang login untuk mengecek data penduduk secara individu (untuk auto-fill)
      // Namun larang pengambilan daftar seluruh penduduk (list) kecuali admin.
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /complaints/{id} {
      allow create: if true; 
      allow read: if isAdmin() || (isSignedIn() && resource.data.submitterAuthUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /letterRequests/{id} {
      allow create: if isSignedIn();
      allow read, delete: if isAdmin() || (isSignedIn() && resource.data.requestorAuthUid == request.auth.uid);
      allow update: if isAdmin();
    }
    
    match /citizens/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /counters/{id} {
      allow read, write: if true;
    }

    // --- FALLBACK ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}